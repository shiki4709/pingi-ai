# ─── Pingi AI - Phase 0 Config ───

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail OAuth2
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_REFRESH_TOKEN=

# X / Twitter API v2
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
# Your Twitter user ID (numeric) — find at tweeterid.com
TWITTER_USER_ID=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
# Your LinkedIn person URN (e.g., urn:li:person:ABC123)
LINKEDIN_PERSON_URN=

# ─── Digest Settings ───
# How many hours back to look for items (default: 24)
LOOKBACK_HOURS=24

# Your tone description for AI drafts
TONE_DESCRIPTION=Professional but friendly. Uses casual language when appropriate. Concise. Sometimes uses emojis sparingly.

# Optional: email yourself the digest
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DIGEST_EMAIL=

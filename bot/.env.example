# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=random_secret_string

# Server
PORT=3001
HOST=0.0.0.0

# Webhook URL (production — your public URL, e.g. from ngrok)
# Leave blank or unset to use long polling for local dev
# WEBHOOK_URL=https://your-domain.com/webhook

# Long polling timeout in seconds (only used in polling mode)
# POLLING_TIMEOUT_SEC=30

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Gmail OAuth (shared with web app)
GMAIL_CLIENT_ID=your_google_client_id
GMAIL_CLIENT_SECRET=your_google_client_secret

# Anthropic (Claude API for draft generation)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Digest schedule (hours between digest sends)
DIGEST_INTERVAL_HOURS=4

# Twitter/X — for mentions monitoring (API v2)
# TWITTER_BEARER_TOKEN=your_twitter_bearer_token
# TWITTER_USER_ID=your_twitter_numeric_user_id

# Twitter/X — cookie auth (preferred, get from browser DevTools → Application → Cookies → x.com)
# Option A: JSON array format (used by @the-convocation/twitter-scraper)
# TWITTER_COOKIES='[{"name":"auth_token","value":"xxx","domain":".twitter.com"},{"name":"ct0","value":"xxx","domain":".twitter.com"}]'
# Option B: individual values
# X_AUTH_TOKEN=your_auth_token_cookie_value
# X_CT0=your_ct0_cookie_value

# Twitter/X — OAuth 1.0a for posting replies (from developer.twitter.com)
# TWITTER_API_KEY=your_api_key
# TWITTER_API_SECRET=your_api_secret
# TWITTER_ACCESS_TOKEN=your_access_token
# TWITTER_ACCESS_SECRET=your_access_token_secret

# Twitter/X — password login fallback for reading (all three required)
# TWITTER_USERNAME=your_twitter_username
# TWITTER_PASSWORD=your_twitter_password
# TWITTER_EMAIL=your_twitter_email

# X Engagement Bot (separate process — @pingi_x_bot)
# TELEGRAM_X_BOT_TOKEN=your_x_bot_token_from_botfather
# X_BOT_PORT=3002
# X_BOT_WEBHOOK_URL=https://your-domain.com/webhook
# X_BOT_WEBHOOK_SECRET=random_secret_string
